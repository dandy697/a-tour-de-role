# ─── Database (Supabase) ──────────────────────────────────────────────────────
# Get from: supabase.com → Settings → Database → Connection string
DATABASE_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres.[ref]:[password]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Get from: console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="xxx.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="GOCSPX-xxx"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate: openssl rand -base64 32
NEXTAUTH_SECRET="your-secret-here"
NEXTAUTH_URL="https://atourderole.vercel.app"

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Get from: dashboard.stripe.com → Developers → API Keys
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
STRIPE_PRICE_PRO="price_..."
STRIPE_PRICE_PREMIUM="price_..."

# ─── Email (Brevo) ────────────────────────────────────────────────────────────
# Get from: app.brevo.com → SMTP & API → API Keys
# Free tier: 300 emails/jour, hébergé EU, RGPD natif
BREVO_API_KEY="xkeysib-..."
BREVO_SENDER_EMAIL="hello@atourderole.tk"

# ─── Push Notifications (Web Push / VAPID) ────────────────────────────────────
# Generate keys once: npx web-push generate-vapid-keys
# NEXT_PUBLIC_ prefix = exposed au navigateur (clé publique uniquement)
NEXT_PUBLIC_VAPID_PUBLIC_KEY="Bxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VAPID_PRIVATE_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"
VAPID_EMAIL="mailto:hello@atourderole.tk"

# ─── App ──────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="https://atourderole.vercel.app"
